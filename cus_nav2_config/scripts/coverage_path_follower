#!/usr/bin/env python3
"""
Coverage Path Follower
======================
Bridge between ros2_plan_publisher and Nav2's FollowPath action server.

Subscribes to:
  /coverage_path   nav_msgs/Path    — full path from plan publisher
  /coverage_start  std_msgs/Bool    — True = start following the current path
  /coverage_stop   std_msgs/Bool    — True  = pause (cancel active goal, remember path)
                                      False = resume (re-send stored path from current pos)

Calls Nav2 action:
  /follow_path     nav2_msgs/action/FollowPath  (controller_server)

Pause / resume behaviour
------------------------
  True  → cancels the active FollowPath goal; robot coasts to a stop.
  False → re-sends the same full path; Pure Pursuit picks up from the
          nearest waypoint to the robot's current position automatically.

Usage:
  ros2 run cus_nav2_config coverage_path_follower
"""

import rclpy
from rclpy.node import Node
from rclpy.action import ActionClient
from rclpy.action.client import GoalStatus
from rclpy.qos import QoSProfile, DurabilityPolicy, ReliabilityPolicy
from nav_msgs.msg import Path
from std_msgs.msg import Bool
from nav2_msgs.action import FollowPath, NavigateToPose


class CoveragePathFollower(Node):

    def __init__(self):
        super().__init__('coverage_path_follower')

        # Action clients
        self._action_client = ActionClient(self, FollowPath, '/follow_path')
        self._nav_client    = ActionClient(self, NavigateToPose, '/navigate_to_pose')

        # State
        self._current_path = None
        self._goal_handle = None
        self._nav_handle  = None      # handle for NavigateToPose (go-to-start phase)
        self._is_following = False
        self._is_navigating_to_start = False
        self._paused = False          # True while paused (goal cancelled, path retained)

        # TRANSIENT_LOCAL QoS for /coverage_start so the signal is received
        # even if this node subscribes after the HMI publishes it
        _start_qos = QoSProfile(depth=1)
        _start_qos.durability  = DurabilityPolicy.TRANSIENT_LOCAL
        _start_qos.reliability = ReliabilityPolicy.RELIABLE

        # Subscriptions
        self.create_subscription(Path, '/coverage_path',  self._cb_path,  10)
        self.create_subscription(Bool, '/coverage_start', self._cb_start, _start_qos)
        self.create_subscription(Bool, '/coverage_stop',  self._cb_stop,  10)

        self.get_logger().info('Coverage path follower ready — waiting for path and start signal')

    # ── Callbacks ─────────────────────────────────────────────────────────────

    def _cb_path(self, msg: Path):
        """Store the latest path published by ros2_plan_publisher."""
        self._current_path = msg

    def _cb_start(self, msg: Bool):
        """Start following the current path when True is received."""
        if not msg.data:
            return
        if self._is_following or self._is_navigating_to_start:
            self.get_logger().info('Already active; ignoring start signal')
            return
        if not self._current_path or not self._current_path.poses:
            self.get_logger().warn('No path available yet; ignoring start signal')
            return
        # Fresh start: drive to the first waypoint first so we always begin
        # from waypoint 0 regardless of where the robot currently is.
        self._navigate_to_start()

    def _cb_stop(self, msg: Bool):
        """Pause (True) or resume (False) autonomous navigation."""
        if msg.data:
            # ── PAUSE ────────────────────────────────────────────────────────
            self._paused = True
            if self._nav_handle is not None and self._is_navigating_to_start:
                self.get_logger().info('PAUSE received — cancelling navigate-to-start')
                self._nav_handle.cancel_goal_async()
                self._is_navigating_to_start = False
                self._nav_handle = None
            elif self._goal_handle is not None and self._is_following:
                self.get_logger().info('PAUSE received — cancelling active goal')
                future = self._goal_handle.cancel_goal_async()
                future.add_done_callback(self._cancel_done_cb)
            else:
                pass  # mark paused even if no goal active
        else:
            # ── RESUME ───────────────────────────────────────────────────────
            if not self._paused:
                return   # spurious False; do nothing
            self._paused = False
            if self._current_path and self._current_path.poses and not self._is_following:
                self.get_logger().info('RESUME received — re-sending coverage path')
                self._send_goal()
            else:
                self.get_logger().info('RESUME received but no path available or already running')

    # ── Goal management ───────────────────────────────────────────────────────

    def _navigate_to_start(self):
        """Drive to the first waypoint of the path before starting FollowPath.

        This ensures the robot always begins coverage from waypoint 0 rather
        than latching onto the nearest point mid-path (which is what Pure Pursuit
        does when given the full path cold).
        """
        first_pose = self._current_path.poses[0]
        goal = NavigateToPose.Goal()
        goal.pose = first_pose

        self.get_logger().info(
            f'Navigating to path start  '
            f'({first_pose.pose.position.x:.2f}, {first_pose.pose.position.y:.2f})'
        )

        if not self._nav_client.wait_for_server(timeout_sec=5.0):
            self.get_logger().warn(
                'NavigateToPose server not available — '
                'starting FollowPath from nearest point instead'
            )
            self._send_goal()
            return

        self._is_navigating_to_start = True
        future = self._nav_client.send_goal_async(goal)
        future.add_done_callback(self._nav_to_start_response_cb)

    def _nav_to_start_response_cb(self, future):
        handle = future.result()
        if not handle.accepted:
            self.get_logger().warn(
                'NavigateToPose goal rejected — starting from nearest point'
            )
            self._is_navigating_to_start = False
            self._send_goal()
            return
        self._nav_handle = handle
        result_future = handle.get_result_async()
        result_future.add_done_callback(self._nav_to_start_result_cb)

    def _nav_to_start_result_cb(self, future):
        self._is_navigating_to_start = False
        self._nav_handle = None

        if self._paused:
            self.get_logger().info('Paused during navigate-to-start; not starting FollowPath')
            return

        result = future.result()
        if result.status == GoalStatus.STATUS_SUCCEEDED:
            self.get_logger().info('Reached path start — beginning coverage path following')
        else:
            self.get_logger().warn(
                f'Navigate-to-start ended with status {result.status} — '
                'starting FollowPath from nearest point'
            )
        self._send_goal()

    def _send_goal(self):
        if not self._action_client.wait_for_server(timeout_sec=5.0):
            self.get_logger().error(
                'FollowPath action server not available after 5 s — '
                'is controller_server running?'
            )
            return

        goal_msg = FollowPath.Goal()
        goal_msg.path = self._current_path
        goal_msg.controller_id = 'FollowPath'    # must match controller_plugins key in yaml
        goal_msg.goal_checker_id = 'stopped_goal_checker'

        self._is_following = True
        self.get_logger().info(
            f'Sending path with {len(self._current_path.poses)} poses to /follow_path'
        )

        send_future = self._action_client.send_goal_async(
            goal_msg,
            feedback_callback=self._feedback_cb,
        )
        send_future.add_done_callback(self._goal_response_cb)

    def _goal_response_cb(self, future):
        handle = future.result()
        if not handle.accepted:
            self.get_logger().warn('Goal was REJECTED by controller_server')
            self._is_following = False
            return
        self._goal_handle = handle
        self.get_logger().info('Goal ACCEPTED — robot is now following the coverage path')
        result_future = handle.get_result_async()
        result_future.add_done_callback(self._result_cb)

    def _result_cb(self, future):
        self._is_following = False
        self._goal_handle = None
        result = future.result()
        status = result.status
        if status == GoalStatus.STATUS_SUCCEEDED:
            self._paused = False
            self.get_logger().info('Coverage path following SUCCEEDED')
        elif status == GoalStatus.STATUS_CANCELED:
            # paused → _paused stays True so resume can re-send
            if not self._paused:
                self.get_logger().info('Coverage path following CANCELLED (full stop)')
            else:
                self.get_logger().info('Coverage path following PAUSED — send resume to continue')
        else:
            self._paused = False
            self.get_logger().warn(f'Coverage path following ended with status {status}')

    def _feedback_cb(self, feedback_msg):
        fb = feedback_msg.feedback
        self.get_logger().info(
            f'Distance to goal: {fb.distance_to_goal:.2f} m  '
            f'speed: {fb.speed:.3f} m/s',
            throttle_duration_sec=3.0,
        )

    def _cancel_done_cb(self, future):
        # _result_cb will fire after this and set _is_following = False
        self.get_logger().info('Cancel request accepted by action server')


# ── Entry point ───────────────────────────────────────────────────────────────

def main(args=None):
    rclpy.init(args=args)
    node = CoveragePathFollower()
    try:
        rclpy.spin(node)
    except KeyboardInterrupt:
        pass
    finally:
        node.destroy_node()
        rclpy.shutdown()


if __name__ == '__main__':
    main()
