#!/usr/bin/env python3
"""
Coverage Path Follower
======================
Waits for /coverage_start, then builds and publishes /updated_path ONCE on a
TRANSIENT_LOCAL (latched) topic.  The path is:

    current_pose → start_point (interpolated)  +  full coverage path

cus_pure_pursuit subscribes to /updated_path and uses its own nearest-point
logic to advance along the static path, so republishing is unnecessary.

Subscribes
----------
  /coverage_path   nav_msgs/Path               — full plan from ros2_plan_publisher
  /current_pose    geometry_msgs/PoseStamped   — live pose from cus_pose_compute
  /coverage_start  std_msgs/Bool               — True = build & publish /updated_path
  /coverage_stop   std_msgs/Bool               — True = publish empty path (stop signal)
  /start_point     geometry_msgs/PoseStamped   — override the coverage start point

Publishes
---------
  /updated_path    nav_msgs/Path  — TRANSIENT_LOCAL, published once on start

Parameters
----------
  max_interp_dist (float)  max metres between waypoints [default: 0.2]
  frame_id        (str)    TF frame                     [default: map]
"""

import math
import rclpy
from rclpy.node import Node
from rclpy.qos import QoSProfile, DurabilityPolicy, ReliabilityPolicy
from geometry_msgs.msg import PoseStamped, Point
from nav_msgs.msg import Path
from std_msgs.msg import Bool, Header


# ──────────────────────────────────────────────────────────────────────────────
# Geometry helpers
# ──────────────────────────────────────────────────────────────────────────────

def interpolate_segment(x0, y0, x1, y1, max_dist: float) -> list:
    """Return a list of dicts for a straight segment."""
    dx, dy = x1 - x0, y1 - y0
    dist = math.hypot(dx, dy)
    yaw  = math.atan2(dy, dx)
    if dist <= max_dist or dist < 1e-6:
        return [{"x": x1, "y": y1, "yaw": yaw}]
    n_steps = math.ceil(dist / max_dist)
    pts = []
    for i in range(1, n_steps + 1):
        t = i / n_steps
        pts.append({"x": x0 + dx * t, "y": y0 + dy * t, "yaw": yaw})
    return pts


def make_pose_stamped(x: float, y: float, yaw: float, header: Header) -> PoseStamped:
    ps = PoseStamped()
    ps.header = header
    ps.pose.position = Point(x=x, y=y, z=0.0)
    ps.pose.orientation.z = math.sin(yaw / 2.0)
    ps.pose.orientation.w = math.cos(yaw / 2.0)
    return ps


# ──────────────────────────────────────────────────────────────────────────────
# Node
# ──────────────────────────────────────────────────────────────────────────────

class CoveragePathFollower(Node):

    def __init__(self):
        super().__init__("coverage_path_follower")

        self.declare_parameter("max_interp_dist", 0.2)
        self.declare_parameter("frame_id",        "map")

        self._max_dist = self.get_parameter("max_interp_dist").value
        self._frame_id = self.get_parameter("frame_id").value

        # State
        self._coverage_path: Path = None
        self._current_pose: PoseStamped = None
        self._start_point: PoseStamped  = None

        # TRANSIENT_LOCAL publisher — pure_pursuit receives the path even if it
        # starts after /coverage_start is processed.
        _lqos = QoSProfile(depth=1)
        _lqos.durability  = DurabilityPolicy.TRANSIENT_LOCAL
        _lqos.reliability = ReliabilityPolicy.RELIABLE
        self._pub_path = self.create_publisher(Path, "/updated_path", _lqos)

        # TRANSIENT_LOCAL for /coverage_start so we receive it even if published
        # before this node finishes starting up.
        _start_qos = QoSProfile(depth=1)
        _start_qos.durability  = DurabilityPolicy.TRANSIENT_LOCAL
        _start_qos.reliability = ReliabilityPolicy.RELIABLE

        # /coverage_path is published TRANSIENT_LOCAL by ros2_plan_publisher
        _path_qos = QoSProfile(depth=1)
        _path_qos.durability  = DurabilityPolicy.TRANSIENT_LOCAL
        _path_qos.reliability = ReliabilityPolicy.RELIABLE

        self.create_subscription(Path,        "/coverage_path",  self._cb_coverage_path, _path_qos)
        self.create_subscription(PoseStamped, "/current_pose",   self._cb_current_pose,  10)
        self.create_subscription(Bool,        "/coverage_start", self._cb_start, _start_qos)
        self.create_subscription(Bool,        "/coverage_stop",  self._cb_stop,  10)
        self.create_subscription(PoseStamped, "/start_point",    self._cb_start_point, 10)

        self.get_logger().info(
            "coverage_path_follower ready — waiting for /coverage_path and /coverage_start"
        )

    # ── Callbacks ─────────────────────────────────────────────────────────────

    def _cb_coverage_path(self, msg: Path):
        self._coverage_path = msg

    def _cb_current_pose(self, msg: PoseStamped):
        self._current_pose = msg

    def _cb_start(self, msg: Bool):
        if not msg.data:
            return
        if not self._coverage_path or not self._coverage_path.poses:
            self.get_logger().warn("No coverage path yet — ignoring start signal")
            return
        path = self._build_updated_path()
        self._pub_path.publish(path)
        self.get_logger().info(
            f"Published /updated_path: {len(path.poses)} poses (TRANSIENT_LOCAL)"
        )

    def _cb_stop(self, msg: Bool):
        if msg.data:
            h = self._make_header()
            self._pub_path.publish(Path(header=h))
            self.get_logger().info("Coverage STOPPED — empty /updated_path published")

    def _cb_start_point(self, msg: PoseStamped):
        self._start_point = msg
        self.get_logger().info(
            f"Start point updated to "
            f"({msg.pose.position.x:.2f}, {msg.pose.position.y:.2f})"
        )

    # ── Helpers ───────────────────────────────────────────────────────────────

    def _make_header(self) -> Header:
        h = Header()
        h.stamp    = self.get_clock().now().to_msg()
        h.frame_id = self._frame_id
        return h

    def _get_start_xy(self):
        if self._start_point is not None:
            return (self._start_point.pose.position.x,
                    self._start_point.pose.position.y)
        if self._coverage_path and self._coverage_path.poses:
            fp = self._coverage_path.poses[0].pose.position
            return (fp.x, fp.y)
        return None

    def _build_updated_path(self) -> Path:
        header = self._make_header()
        path   = Path()
        path.header = header

        start_xy = self._get_start_xy()
        if start_xy is None:
            return path

        # current_pose → start_point
        if self._current_pose is not None:
            rx = self._current_pose.pose.position.x
            ry = self._current_pose.pose.position.y
            sx, sy = start_xy
            for pt in interpolate_segment(rx, ry, sx, sy, self._max_dist):
                path.poses.append(make_pose_stamped(pt["x"], pt["y"], pt["yaw"], header))

        # Full coverage path
        for ps in self._coverage_path.poses:
            p = PoseStamped()
            p.header = header
            p.pose   = ps.pose
            path.poses.append(p)

        return path


# ── Entry point ───────────────────────────────────────────────────────────────

def main(args=None):
    rclpy.init(args=args)
    node = CoveragePathFollower()
    try:
        rclpy.spin(node)
    except KeyboardInterrupt:
        pass
    finally:
        node.destroy_node()
        rclpy.shutdown()


if __name__ == "__main__":
    main()
