#!/usr/bin/env python3
"""
ROS2 Coverage Plan Publisher
============================
Reads the JSON plan saved by coverage_planner.py and publishes the waypoints
once as a nav_msgs/Path on a TRANSIENT_LOCAL (latched) topic so that any node
subscribing later still receives the path immediately.

Published topics
----------------
  /coverage_path   nav_msgs/Path    — full interpolated path (TRANSIENT_LOCAL)
  /coverage_status std_msgs/String  — JSON status blob (TRANSIENT_LOCAL)

Parameters
----------
  plan_file        (str)   path to the JSON plan          [default: coverage_plan.json]
  sequence         (str)   comma-separated zone order     [default: plan's own sequence]
  frame_id         (str)   TF frame for all messages      [default: map]
  max_interp_dist  (float) max metres between waypoints   [default: 0.2]
"""

import json
import math
import os
import sys

try:
    import rclpy
    from rclpy.node import Node
    from rclpy.qos import QoSProfile, DurabilityPolicy, ReliabilityPolicy
    from geometry_msgs.msg import PoseStamped, Quaternion, Point
    from nav_msgs.msg import Path
    from std_msgs.msg import Header, String
except ImportError:
    print("rclpy not found — source your ROS2 setup.bash and try again.")
    sys.exit(1)


# ──────────────────────────────────────────────────────────────────────────────
# Helpers
# ──────────────────────────────────────────────────────────────────────────────

def _latched_qos() -> QoSProfile:
    qos = QoSProfile(depth=1)
    qos.durability  = DurabilityPolicy.TRANSIENT_LOCAL
    qos.reliability = ReliabilityPolicy.RELIABLE
    return qos


def yaw_to_quaternion(yaw: float) -> Quaternion:
    return Quaternion(
        x=0.0, y=0.0,
        z=math.sin(yaw / 2.0),
        w=math.cos(yaw / 2.0),
    )


def interpolate_waypoints(waypoints: list, max_dist: float) -> list:
    """Insert intermediate points so no two consecutive waypoints are > max_dist apart."""
    if not waypoints:
        return []
    result = [waypoints[0]]
    for wp in waypoints[1:]:
        prev = result[-1]
        dx = wp["x"] - prev["x"]
        dy = wp["y"] - prev["y"]
        dist = math.hypot(dx, dy)
        if dist > max_dist and dist > 1e-6:
            n_steps = math.ceil(dist / max_dist)
            yaw = math.atan2(dy, dx)
            for i in range(1, n_steps):
                t = i / n_steps
                result.append({
                    "x": prev["x"] + dx * t,
                    "y": prev["y"] + dy * t,
                    "yaw": yaw,
                })
        result.append(wp)
    return result


def waypoints_to_path(waypoints: list, header: Header) -> Path:
    path = Path()
    path.header = header
    for wp in waypoints:
        ps = PoseStamped()
        ps.header = header
        ps.pose.position = Point(x=wp["x"], y=wp["y"], z=0.0)
        ps.pose.orientation = yaw_to_quaternion(wp.get("yaw", 0.0))
        path.poses.append(ps)
    return path


# ──────────────────────────────────────────────────────────────────────────────
# Node
# ──────────────────────────────────────────────────────────────────────────────

class CoveragePlanPublisher(Node):

    def __init__(self):
        super().__init__("coverage_plan_publisher")

        # Resolve default plan_file path
        _default_plan = "coverage_plan.json"
        try:
            from ament_index_python.packages import get_package_share_directory
            _pkg = get_package_share_directory("cus_nav2_config")
            _default_plan = os.path.join(_pkg, "paths", "coverage_plan.json")
        except Exception:
            pass

        self.declare_parameter("plan_file",       _default_plan)
        self.declare_parameter("sequence",        "")
        self.declare_parameter("frame_id",        "map")
        self.declare_parameter("max_interp_dist", 0.2)

        # TRANSIENT_LOCAL so late subscribers (e.g. coverage_path_follower) still
        # receive the path even if they start after this node publishes.
        lqos = _latched_qos()
        self._pub_path   = self.create_publisher(Path,   "/coverage_path",   lqos)
        self._pub_status = self.create_publisher(String, "/coverage_status", lqos)

        plan_file  = self.get_parameter("plan_file").value
        self._plan = self._load_plan(plan_file)
        self.get_logger().info(
            f"Plan loaded: '{plan_file}'  "
            f"({len(self._plan.get('zones', {}))} zones)"
        )

        # Publish once — a short delay lets the publisher fully register before
        # the message is sent (avoids a race on the same spin tick).
        self._once_timer = self.create_timer(0.1, self._publish_once)

    # ── Plan loading ──────────────────────────────────────────────────────────

    def _load_plan(self, path: str) -> dict:
        try:
            with open(path) as f:
                return json.load(f)
        except FileNotFoundError:
            self.get_logger().error(f"Plan file not found: '{path}'")
            return {}
        except json.JSONDecodeError as exc:
            self.get_logger().error(f"JSON parse error in '{path}': {exc}")
            return {}

    # ── Helpers ───────────────────────────────────────────────────────────────

    def _active_sequence(self):
        zones    = self._plan.get("zones", {})
        override = self.get_parameter("sequence").value.strip()
        if override:
            keys = [k.strip() for k in override.split(",") if k.strip() in zones]
            if keys:
                return keys
        seq = self._plan.get("sequence", list(zones.keys()))
        return [k for k in seq if k in zones]

    def _make_header(self) -> Header:
        h = Header()
        h.stamp    = self.get_clock().now().to_msg()
        h.frame_id = self.get_parameter("frame_id").value
        return h

    # ── One-shot publish ──────────────────────────────────────────────────────

    def _publish_once(self):
        # Cancel the timer so this only fires once
        self._once_timer.cancel()

        if not self._plan:
            return

        max_dist = self.get_parameter("max_interp_dist").value
        seq      = self._active_sequence()
        zones    = self._plan.get("zones", {})
        header   = self._make_header()

        all_wps = []
        for key in seq:
            all_wps.extend(interpolate_waypoints(zones[key].get("waypoints", []), max_dist))

        self._pub_path.publish(waypoints_to_path(all_wps, header))

        status = {
            "sequence":    seq,
            "total_zones": len(seq),
            "total_wps":   len(all_wps),
            "frame_id":    self.get_parameter("frame_id").value,
        }
        self._pub_status.publish(String(data=json.dumps(status)))

        self.get_logger().info(
            f"Published /coverage_path: {len(all_wps)} waypoints across {len(seq)} zones "
            f"(TRANSIENT_LOCAL — latched)"
        )


# ──────────────────────────────────────────────────────────────────────────────
# Entry point
# ──────────────────────────────────────────────────────────────────────────────

def main(args=None):
    rclpy.init(args=args)
    node = CoveragePlanPublisher()
    try:
        rclpy.spin(node)
    except KeyboardInterrupt:
        pass
    finally:
        node.destroy_node()
        rclpy.shutdown()


if __name__ == "__main__":
    main()
