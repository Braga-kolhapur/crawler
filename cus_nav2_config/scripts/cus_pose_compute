#!/usr/bin/env python3
"""
Custom Pose Compute Node
========================
Maintains a continuously updated robot pose estimate by:
  1. Bootstrapping from /initialpose so odom integration starts immediately.
  2. Correcting the estimate whenever /amcl_pose arrives.
  3. Integrating /odom velocities (Euler) between fixes.

Pose is published at a fixed rate (publish_hz) via a timer, independent of
whether odom or AMCL messages are currently arriving.

Publishes
---------
  /current_pose   geometry_msgs/PoseStamped  — best-estimate pose in map frame

Subscribes
----------
  /initialpose    geometry_msgs/PoseWithCovarianceStamped  — bootstrap
  /amcl_pose      geometry_msgs/PoseWithCovarianceStamped  — AMCL correction
  /odom           nav_msgs/Odometry

Parameters
----------
  publish_hz  (float)  publish rate in Hz  [default: 10.0]
"""

import math
import time
import rclpy
from rclpy.node import Node
from geometry_msgs.msg import PoseStamped, PoseWithCovarianceStamped
from nav_msgs.msg import Odometry


class CusPoseCompute(Node):

    def __init__(self):
        super().__init__("cus_pose_compute")

        self.declare_parameter("publish_hz", 10.0)
        hz = max(0.1, self.get_parameter("publish_hz").value)

        # Pose state (map frame)
        self._x   = 0.0
        self._y   = 0.0
        self._yaw = 0.0

        # Wall-clock time of last odom integration step
        self._last_odom_t: float = None

        # True once we have at least one pose fix
        self._has_pose = False

        # Publisher
        self._pub = self.create_publisher(PoseStamped, "/current_pose", 10)

        # Fixed-rate publish timer — decoupled from odom/AMCL arrival rate
        self.create_timer(1.0 / hz, self._publish)

        # Subscribers
        self.create_subscription(
            PoseWithCovarianceStamped, "/initialpose",
            self._cb_initial_pose, 10
        )
        self.create_subscription(
            PoseWithCovarianceStamped, "/amcl_pose",
            self._cb_amcl, 10
        )
        self.create_subscription(
            Odometry, "/odom",
            self._cb_odom, 10
        )

        self.get_logger().info(
            f"cus_pose_compute ready at {hz:.1f} Hz — "
            "waiting for /initialpose or /amcl_pose"
        )

    # ── Callbacks ─────────────────────────────────────────────────────────────

    def _cb_initial_pose(self, msg: PoseWithCovarianceStamped):
        """Bootstrap from user-set initial pose (before AMCL converges)."""
        if self._has_pose:
            # Once AMCL has taken over, ignore repeated /initialpose clicks.
            # Re-localisation will come via /amcl_pose.
            return
        self._accept_pose(msg, source="initialpose")

    def _cb_amcl(self, msg: PoseWithCovarianceStamped):
        """Snap pose to AMCL ground truth."""
        self._accept_pose(msg, source="amcl_pose")

    def _accept_pose(self, msg: PoseWithCovarianceStamped, source: str):
        p = msg.pose.pose
        self._x   = p.position.x
        self._y   = p.position.y
        self._yaw = self._quat_to_yaw(p.orientation)
        # Reset integration baseline
        self._last_odom_t = None
        if not self._has_pose:
            self._has_pose = True
            self.get_logger().info(
                f"Pose bootstrapped from /{source}: "
                f"({self._x:.2f}, {self._y:.2f}, "
                f"yaw={math.degrees(self._yaw):.1f}°)"
            )

    def _cb_odom(self, msg: Odometry):
        """Integrate odom velocities between pose fixes."""
        if not self._has_pose:
            return

        now = time.monotonic()

        if self._last_odom_t is None:
            self._last_odom_t = now
            return

        dt = now - self._last_odom_t
        self._last_odom_t = now

        # Reject unreasonable dt
        if dt <= 0.0 or dt > 1.0:
            return

        vx = msg.twist.twist.linear.x
        wz = msg.twist.twist.angular.z

        self._x   += vx * math.cos(self._yaw) * dt
        self._y   += vx * math.sin(self._yaw) * dt
        self._yaw += wz * dt
        self._yaw  = math.atan2(math.sin(self._yaw), math.cos(self._yaw))

    # ── Timer publish ──────────────────────────────────────────────────────────

    def _publish(self):
        if not self._has_pose:
            return
        msg = PoseStamped()
        msg.header.stamp    = self.get_clock().now().to_msg()
        msg.header.frame_id = "map"
        msg.pose.position.x = self._x
        msg.pose.position.y = self._y
        msg.pose.position.z = 0.0
        msg.pose.orientation.z = math.sin(self._yaw / 2.0)
        msg.pose.orientation.w = math.cos(self._yaw / 2.0)
        self._pub.publish(msg)

    # ── Helpers ───────────────────────────────────────────────────────────────

    @staticmethod
    def _quat_to_yaw(q) -> float:
        siny = 2.0 * (q.w * q.z + q.x * q.y)
        cosy = 1.0 - 2.0 * (q.y * q.y + q.z * q.z)
        return math.atan2(siny, cosy)


# ── Entry point ───────────────────────────────────────────────────────────────

def main(args=None):
    rclpy.init(args=args)
    node = CusPoseCompute()
    try:
        rclpy.spin(node)
    except KeyboardInterrupt:
        pass
    finally:
        node.destroy_node()
        rclpy.shutdown()


if __name__ == "__main__":
    main()
